    },
    "./store/file-store.js": {
      "types": "./src/store/file-store.ts",
      "default": "./dist/store/file-store.js"
    },
    "./templates/seed.js": {
      "types": "./src/templates/seed.ts",
      "default": "./dist/templates/seed.js"
    },
    "./repair/signature.js": {
      "types": "./src/repair/signature.ts",
      "default": "./dist/repair/signature.js"
